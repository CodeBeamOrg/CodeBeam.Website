@using CodeBeam.Website.Client.Brand
@inherits LayoutComponentBase
@inject NavigationManager Nav
@inject IJSRuntime JS

<MudThemeProvider @ref="@_mudThemeProvider" Theme="_codeBeamTheme" @bind-IsDarkMode="@_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<a id="home"></a>
<MudLayout Style="@(_isDarkMode ? "background: radial-gradient(circle at top, #2E2D4D, #1e1d35)" : null)">
    <MudAppBar Class="cb-blur" Color="Color.Transparent" Dense="true" Elevation="0">
        <div class="cb-mobile">
            <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Primary" Edge="Edge.Start" OnClick="@(() => _isOpen = !_isOpen)" />
        </div>
        <MudIcon Class="cursor-pointer" Icon="@CodeBeamBrands.CodeBeam" Color="Color.Primary" @onclick="@(() => Nav.NavigateTo("/#home"))" />
        <MudText Class="ml-2 cursor-pointer" Style="user-select: none" Typo="Typo.h6" Color="Color.Primary" Align="Align.Center" @onclick="@(() => Nav.NavigateTo("/#home"))">CodeBeam</MudText>
        <MudSpacer />
        <div class="cb-desktop">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.Center" Spacing="6">
                <MudMenu Class="@(!RendererInfo.IsInteractive ? "fade-right delay-1" : null)" ActivationEvent="MouseEvent.MouseOver" Dense="true" PopoverClass="mud-theme-primary" RelativeWidth="DropdownWidth.Relative">
                    <ActivatorContent>
                        <MudText Color="Color.Primary"><MudLink Class="pa-2" Href="/#vision" Underline="Underline.None">Vision</MudLink></MudText>
                    </ActivatorContent>
                </MudMenu>
                <MudMenu Class="@(!RendererInfo.IsInteractive ? "fade-right delay-2" : null)" ActivationEvent="MouseEvent.MouseOver" Dense="true" PopoverClass="mud-theme-primary" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                    <ActivatorContent>
                        <MudText Color="Color.Primary"><MudLink Class="cb-primary-hover cb-transition pa-2" Underline="Underline.None" Href="/#products">Products</MudLink></MudText>
                    </ActivatorContent>
                    <ChildContent>
                        <MudMenuItem Class="cb-menu-item" Href="/#ultimateauth">
                            <MudStack Class="mud-width-full" Row="true" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@CodeBeamBrands.UltimateAuth" />
                                <MudStack Spacing="0">
                                    <MudText><b>UltimateAuth</b></MudText>
                                    <MudText Typo="Typo.subtitle2">Modern & Unified Auth Framework for .NET</MudText>
                                </MudStack>
                            </MudStack>
                        </MudMenuItem>
                        <MudDivider Class="my-2" />
                        <MudMenuItem Class="cb-menu-item mt-4" Href="/#mudblazor-extensions">
                            <MudStack Class="mud-width-full" Row="true" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Custom.Brands.MudBlazor" />
                                <MudStack Spacing="0">
                                    <MudText><b>MudBlazor Extensions</b></MudText>
                                    <MudText Typo="Typo.subtitle2">30+ Extension Component for MudBlazor</MudText>
                                </MudStack>
                            </MudStack>
                        </MudMenuItem>
                        <MudMenuItem Class="cb-menu-item mt-4" Href="/#bcss">
                            <MudStack Class="mud-width-full" Row="true" AlignItems="AlignItems.Center">
                                <MudImage Src="BCSS.jpg" Style="width: 24px" Fluid="true" />
                                <MudStack Spacing="0">
                                    <MudText><b>BCSS</b></MudText>
                                    <MudText Typo="Typo.subtitle2">Revolutionary Runtime CSS Generator for Blazor</MudText>
                                </MudStack>
                            </MudStack>
                        </MudMenuItem>
                        <MudMenuItem Class="cb-menu-item mt-4" Href="/#googleapis">
                            <MudStack Class="mud-width-full" Row="true" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.Api" />
                                <MudStack Spacing="0">
                                    <MudText><b>GoogleApis</b></MudText>
                                    <MudText Typo="Typo.subtitle2">Google Api Integration for Blazor</MudText>
                                </MudStack>
                            </MudStack>
                        </MudMenuItem>
                    </ChildContent>
                </MudMenu>
                <MudMenu Class="@(!RendererInfo.IsInteractive ? "fade-right delay-3" : null)" ActivationEvent="MouseEvent.MouseOver" Dense="true" PopoverClass="mud-theme-primary" RelativeWidth="DropdownWidth.Relative">
                    <ActivatorContent>
                        <MudText Color="Color.Primary"><MudLink Class="pa-2" Underline="Underline.None" Href="/#donate">Donate</MudLink></MudText>
                    </ActivatorContent>
                </MudMenu>
            </MudStack>
        </div>
        <MudSpacer />
        <MudIconButton Icon="@Icons.Custom.Brands.GitHub" Color="Color.Primary" Href="https://github.com/CodeBeamOrg" Target="_blank" />
        <MudToggleIconButton @bind-Toggled="@_isDarkMode" Icon="@Icons.Material.Filled.DarkMode" ToggledIcon="@Icons.Material.Filled.LightMode" Color="Color.Primary" ToggledColor="Color.Primary" />
    </MudAppBar>

    <MudDrawer @bind-Open="_isOpen" Breakpoint="Breakpoint.None" ClipMode="DrawerClipMode.Always" Variant="DrawerVariant.Temporary">
        <MudNavMenu>
            <MudNavLink Href="/#home" Icon="@Icons.Material.Filled.Home">Home</MudNavLink>
            <MudNavLink Href="/#vision" Icon="@Icons.Material.Filled.Api">Vision</MudNavLink>
            <MudNavGroup Title="Products" Icon="@Icons.Material.Filled.Dvr">
                <MudNavLink Href="/#ultimateauth">UltimateAuth</MudNavLink>
                <MudNavLink Href="/#mudblazor-extensions">MudBlazor Extensions</MudNavLink>
                <MudNavLink Href="/#bcss">BCSS</MudNavLink>
                <MudNavLink Href="/#googleapis">GoogleApis Blazor</MudNavLink>
            </MudNavGroup>
            <MudNavLink Href="/#donate" Icon="@Icons.Material.Filled.VolunteerActivism">Donate</MudNavLink>
        </MudNavMenu>
    </MudDrawer>
    <MudMainContent>
        @Body
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _isDarkMode = true;
    private MudThemeProvider _mudThemeProvider = null!;
    private bool _isOpen;

    MudTheme _codeBeamTheme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#2E2D4D",
            PrimaryContrastText = "#FEEE88",

            Secondary = "#FEEE88",
        },

        PaletteDark = new PaletteDark()
        {
            Primary = "#FEEE88",
            PrimaryContrastText = "#2E2D4D",

            Secondary = "#2E2D4D",

            Background = "#2E2D4D"
        },
    };

    protected internal bool IsDarkMode => _isDarkMode;
}
