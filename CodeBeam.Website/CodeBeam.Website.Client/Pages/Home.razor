@page "/"
@using CodeBeam.Website.Client.Brand


<div class="relative" style="top: 4px; height: 8px">
    @if (!RendererInfo.IsInteractive)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
</div>
<MudPage FullScreen="FullScreen.FullWithoutAppbar" Row="1" Column="1">
    <MudContainer MaxWidth="MaxWidth.Medium" Class="mud-height-full d-flex align-center justify-center">
        <MudStack Spacing="0">
            <MudText Class="@(!RendererInfo.IsInteractive ? "fade-up delay-1" : null)" Typo="Typo.h4" Color="Color.Primary">CodeBeam</MudText>
            <MudText Class="@(!RendererInfo.IsInteractive ? "fade-up delay-2" : null)" Typo="Typo.h6">Where a Code becomes useful</MudText>
            <MudDivider Class="my-8" Style="width: 120px" />
            <MudText Class="@(!RendererInfo.IsInteractive ? "fade-up delay-4" : null)">Powered by its simplicity. Focused on real-world problems. OpenSource.</MudText>
        </MudStack>
    </MudContainer>
</MudPage>

<a id="vision"></a>
<MudPage FullScreen="FullScreen.Full" Row="1" Column="1">
    <MudContainer MaxWidth="MaxWidth.ExtraSmall" Class="mud-height-full d-flex align-center justify-center my-4">
        <MudPaper Elevation="0" Outlined="true" Class="pa-4" Style="background: transparent">
            <MudStack Spacing="2">
                <MudText Typo="Typo.h4" Color="Color.Primary">Our Vision</MudText>
                <MudDivider Class="my-8" Style="width: 120px" />
                <MudText>We believe software should be simple — even when the problem is not.</MudText>
                <MudText Class="mt-4">At CodeBeam, we focus on building systems that developers can rely on in real-world applications.</MudText>
                <MudText>Our focus is clarity over complexity, practicality over abstraction, and building tools that actually solve problems — not just describe them.</MudText>
                <MudText>From UI extensions to authentication infrastructure, everything we build aims to reduce friction and give developers control.</MudText>
                <MudText>Because good software is not just powerful — it is understandable, predictable, and usable.</MudText>
            </MudStack>
        </MudPaper>
    </MudContainer>
</MudPage>

<a id="products"></a>
<div class="d-flex align-center justify-center" style="height: 20px;">
    <MudText Typo="Typo.h4" Color="Color.Primary" Align="Align.Center">Products</MudText>
</div>

<a id="ultimateauth"></a>
<MudPage FullScreen="FullScreen.Full" Row="1" Column="1">
    <MudContainer MaxWidth="MaxWidth.Large" Class="mud-height-full d-flex flex-column align-center justify-center my-4">
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudStack Class="mud-width-full mud-height-full" Justify="Justify.SpaceBetween">
                    <MudStack Row="true" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@CodeBeamBrands.UltimateAuth" Color="Color.Primary" Style="height: 72px; width: 72px" />
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.h4" Color="Color.Primary">UltimateAuth</MudText>
                            <MudText>The modern unified Auth framework for .NET - Reimagined.</MudText>
                        </MudStack>
                    </MudStack>

                    <MudStack Spacing="2" Class="mt-2">
                        <MudStack Row="true" Spacing="1">
                            <MudChip T="string" Color="Color.Primary" Size="Size.Small" Variant="Variant.Outlined">Authentication</MudChip>
                            <MudChip T="string" Color="Color.Primary" Size="Size.Small" Variant="Variant.Outlined">Security</MudChip>
                            <MudChip T="string" Color="Color.Primary" Size="Size.Small" Variant="Variant.Outlined">Session-based</MudChip>
                            <MudChip T="string" Color="Color.Primary" Size="Size.Small" Variant="Variant.Outlined">Zero-trust</MudChip>
                        </MudStack>

                        <MudStack Row="true" Spacing="4" Class="mt-1">
                            <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Spacing="2">
                                <MudText Typo="Typo.h4" Color="Color.Primary">@Format(_repoStats?.UltimateAuth.Stars ?? 9)</MudText>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudIcon Icon="@Icons.Material.Filled.Star" Color="Color.Primary" Size="Size.Small" />
                                    <MudText Typo="Typo.subtitle2">Stars</MudText>
                                </MudStack>
                            </MudStack>

                            <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Spacing="2">
                                <MudText Typo="Typo.h4" Color="Color.Primary">@Format(_repoStats?.UltimateAuth.Contributors ?? 1)</MudText>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudIcon Icon="@Icons.Material.Filled.People" Color="Color.Primary" Size="Size.Small" />
                                    <MudText Typo="Typo.subtitle2">@GetContributorLabel(_repoStats?.UltimateAuth.Contributors ?? 1)</MudText>
                                </MudStack>
                            </MudStack>

                            <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Spacing="2">
                                <MudText Typo="Typo.h4" Color="Color.Primary">@Format((int?)_repoStats?.UltimateAuth.Downloads ?? 0)</MudText>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudIcon Icon="@Icons.Material.Filled.Download" Color="Color.Primary" Size="Size.Small" />
                                    <MudText Typo="Typo.subtitle2">Downloads</MudText>
                                </MudStack>
                            </MudStack>
                        </MudStack>
                    </MudStack>
                </MudStack>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudStack>
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@Icons.Material.Filled.Check" Color="Color.Primary" Size="Size.Small" />
                        <MudText Typo="Typo.body1" Color="Color.Primary">Flow-based authentication instead of endpoint-driven logic</MudText>
                    </MudStack>
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@Icons.Material.Filled.Check" Color="Color.Primary" Size="Size.Small" />
                        <MudText Typo="Typo.body1" Color="Color.Primary">Session-first architecture with chain & device awareness</MudText>
                    </MudStack>
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@Icons.Material.Filled.Check" Color="Color.Primary" Size="Size.Small" />
                        <MudText Typo="Typo.body1" Color="Color.Primary">Built-in refresh, rotation and reauthentication model</MudText>
                    </MudStack>
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@Icons.Material.Filled.Check" Color="Color.Primary" Size="Size.Small" />
                        <MudText Typo="Typo.body1" Color="Color.Primary">Plugin-based domain system (Users, Credentials, Authorization)</MudText>
                    </MudStack>
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@Icons.Material.Filled.Check" Color="Color.Primary" Size="Size.Small" />
                        <MudText Typo="Typo.body1" Color="Color.Primary">Unified client API for application-level Auth usage</MudText>
                    </MudStack>
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@Icons.Material.Filled.Check" Color="Color.Primary" Size="Size.Small" />
                        <MudText Typo="Typo.body1" Color="Color.Primary">Policy-driven authorization pipeline</MudText>
                    </MudStack>
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@Icons.Material.Filled.Check" Color="Color.Primary" Size="Size.Small" />
                        <MudText Typo="Typo.body1" Color="Color.Primary">Designed for zero-trust security, not just token validation</MudText>
                    </MudStack>
                </MudStack>
            </MudItem>
        </MudGrid>

        <MudStack Class="mt-8">
            <MudDivider />
            <MudStack Row="true" Justify="Justify.Center">
                <MudTooltip Text="GitHub" Color="Color.Primary" Delay="300">
                    <MudIconButton Icon="@Icons.Custom.Brands.GitHub" Color="Color.Primary" Href="https://github.com/CodeBeamOrg/UltimateAuth" Target="_blank" />
                </MudTooltip>

                <MudTooltip Text="NuGet" Color="Color.Primary" Delay="300">
                    <MudIconButton Icon="@Brands.NuGet" Color="Color.Primary" Href="https://www.nuget.org/packages?q=CodeBeam.UltimateAuth&includeComputedFrameworks=true&prerel=true" Target="_blank" />
                </MudTooltip>

                <MudTooltip Text="Web" Color="Color.Primary" Delay="300">
                    <MudIconButton Icon="@Icons.Material.Filled.Language" Color="Color.Primary" Href="https://ultimateauth.com/" Target="_blank" />
                </MudTooltip>
            </MudStack>
        </MudStack>
    </MudContainer>
</MudPage>

